# ROUTRIX Backend Configuration
# Copy this to .env and fill in your values

# ===== SMTP SETTINGS =====
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ===== SECURITY =====
SECRET_KEY=your-secret-key-here-change-in-production
ADMIN_PASSWORD=your-admin-password
DRIVER_PAGE_PASSWORD=your-driver-password

# ===== DATABASE =====
DATABASE_URL=sqlite:///./database/routrix.db

# ===== BACKEND =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=development

# ===== FRONTEND =====
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://routrix.in,https://www.routrix.in

# ===== API KEYS =====
# Google Maps API (optional for advanced features)
GOOGLE_MAPS_API_KEY=
